          "name": "List provinces",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "if (response.data && response.data.length > 0) {",
                  "    ",
                  "    const firstSlug = response.data[0].province_slug;",
                  "    ",
                  "    pm.environment.set(\"province_slug\", firstSlug);",
                  "    ",
                  "    console.log(\"Successfully saved province_slug: \" + firstSlug);",
                  "    ",
                  "} else {",
                  "    console.log(\"No provinces were found in the response.\");",
